{
    "name": "recording-app",
    "version": "1.0.0",
    "type": "module",
    "description": "Desktop Meeting & Screen Recording Application",
    "main": "electron/main.js",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "electron": "electron .",
        "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
        "package": "electron-builder"
    },
    "dependencies": {
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "react-router-dom": "^6.21.0",
        "axios": "^1.6.5"
    },
    "devDependencies": {
        "@vitejs/plugin-react": "^4.2.1",
        "autoprefixer": "^10.4.16",
        "concurrently": "^8.2.2",
        "electron": "^28.1.0",
        "electron-builder": "^24.9.1",
        "postcss": "^8.4.33",
        "tailwindcss": "^3.4.1",
        "vite": "^5.0.11",
        "wait-on": "^7.2.0"
    },
    "build": {
        "appId": "com.recording.app",
        "productName": "Recording App",
        "files": [
            "electron/**/*",
            "dist/**/*"
        ],
        "directories": {
            "output": "release"
        }
    }
}